# DEV .env example

OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-oss-20b:free
LLM_SERVICE_URL=http://llm-service:7000

CORS_ADDRS=http://localhost,http://127.0.0.1

# db
POSTGRES_HOST=db
POSTGRES_USER=YOUR_USER
POSTGRES_DB=YOUR_DB
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_PORT=5432

# quiz_hub
DEBUG=1

# auth
AUTH_PRIVATE_KEY_FILE=/app/secrets/jwt_private.pem

# JWT key
JWT_PUBLIC_KEY_FILE = /app/secrets/jwt_public.pem
# frontend
VITE_AUTH_URL_DEV=http://localhost:8081
